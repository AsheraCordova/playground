<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="MissingPrefix">

    <data></data>

    <LinearLayout
        fragment="SampleMaps"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#e5db54"
        android:orientation="vertical">

        <FrameLayout
            borderBottomWidth="1dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="1dp"
                android:onClick="goToPreviousScreen"
                android:padding="10dp"
                android:text="Back" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <WebView
                android:id="@+id/hiddenBrowser"
                loadUrl="https://asheracordova.github.io/playground/html/location.html"
                os="swt"
                swtStyle="edge"
                android:layout_width="match_parent"
                android:layout_height="20dp" />

            <org.maplibre.android.maps.MapView
                android:id="@+id/maps"
                maplibre_cameraTargetLat="12.93622"
                maplibre_cameraTargetLng="77.57917"
                maplibre_cameraZoom="14"
                maplibre_uiCompass="true"
                maplibre_uiCompassFadeFacingNorth="false"
                onMapClick="onMapClick"
                showMarkerForTarget="true"
                showsUserLocation="true"
                android:layout_width="match_parent"
                android:layout_height="match_parent"></org.maplibre.android.maps.MapView>
        </LinearLayout>
    </LinearLayout>
</layout>